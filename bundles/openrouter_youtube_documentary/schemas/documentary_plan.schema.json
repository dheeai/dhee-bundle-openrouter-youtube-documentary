{
  "type": "object",
  "required": ["title", "centralQuestion", "segments"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "centralQuestion": { "type": "string", "minLength": 1 },
    "viewerPromise": { "type": "string" },
    "segments": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "id",
          "segmentNumber",
          "title",
          "beat",
          "narration",
          "visualThesis",
          "cameraLanguage",
          "durationSec"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^segment_[1-4]$" },
          "segmentNumber": { "type": "integer", "minimum": 1, "maximum": 4 },
          "title": { "type": "string", "minLength": 1 },
          "beat": {
            "type": "string",
            "enum": ["hook", "context", "turning_point", "takeaway"]
          },
          "narration": { "type": "string", "minLength": 1 },
          "visualThesis": { "type": "string", "minLength": 1 },
          "archivalCue": { "type": "string" },
          "interviewCue": { "type": "string" },
          "cameraLanguage": { "type": "string", "minLength": 1 },
          "durationSec": { "type": "integer", "minimum": 6, "maximum": 10 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
